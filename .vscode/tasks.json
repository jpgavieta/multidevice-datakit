{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
        "label": "Mount Proton Datafiles",
        "type": "shell",
        "command": "mkdir -p ~/mnt/proton-data && rclone mount 'proton:Multidevice Datafiles' ~/mnt/proton-data --vfs-cache-mode full --vfs-cache-max-size 1G --daemon",
        "problemMatcher": [],
        "presentation": {
            "reveal": "silent",
            "panel": "dedicated"
        },
        "runOptions": {
            "runOn": "folderOpen"
        }
        },
        {
        "label": "Unmount Proton Datafiles",
        "type": "shell",
        "command": "fusermount -u ~/mnt/proton-data || umount ~/mnt/proton-data",
        "problemMatcher": []
        }
    ]
}